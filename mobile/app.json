{
  "expo": {
    "name": "Prediction Radar",
    "slug": "prediction-radar-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "prediction-radar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
